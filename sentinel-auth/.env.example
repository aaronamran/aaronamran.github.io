# Environment Configuration Template
# Copy this to .env and fill in your actual values

# API Configuration
API_ENDPOINT=https://staging-api.sentinel.internal/verify
PRODUCTION_ENDPOINT=https://api.sentinel.com/v1/auth

# Authentication Secrets (DO NOT COMMIT REAL VALUES)
CLIENT_SECRET=your_client_secret_here
JWT_SIGNING_KEY=your_jwt_signing_key_here
STAGING_SECRET=your_staging_secret_here

# Database (if using backend)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinel_auth
DB_USER=postgres
DB_PASSWORD=your_db_password_here

# Test Account Credentials (Staging Only)
TEST_ADMIN_USER=dev_admin
TEST_ADMIN_PASS=********

# Feature Flags
DEBUG_MODE=true
ENABLE_LOGGING=true
RATE_LIMITING=false

# Network
INTERNAL_GATEWAY=10.0.0.1
ALLOWED_IPS=10.0.0.5,192.168.1.100,172.16.0.50

# Deployment
ENVIRONMENT=staging
VERSION=2.1.4
DEPLOY_DATE=2026-03-08

# Notes:
# - Production secrets are stored in Azure Key Vault
# - Never commit .env file to version control
# - Check git history if you accidentally committed secrets
